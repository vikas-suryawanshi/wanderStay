<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderStay</title>
</head>
<body>
    <h4>edit this:</h4>
    <form method="post" action="/listings/<%= listing._id%>?_method=put">
        <input value="<%=listing.title%>" name="listing[title]" type="text">
        <br/> <br/>
        <textarea rows="7" cols="25" name="listing[description]" type="text"><%=listing.description%></textarea>
        <br/> <br/>
        <input value="<%= listing.price%>" name="listing[price]" type="number">
        <br/> <br/>
        <input value="<%=listing.image%>" name="listing[image]" type="text">
        <br/> <br/>
        <input value="<%= listing.location%>" name="listing[location]" type="text">
        <br/> <br/>
        <input value="<%= listing.country%>" name="listing[country]" type="text">
        <br/> <br/>
        <button>Add</button>
    </form>
</body>
</html>