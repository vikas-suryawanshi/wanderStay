<% layout("/layouts/boilerplate.ejs")  %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h2>listing details:</h2>
    </div>
    <div class="card col-6 offset-2 show-card">
        <img src="<%=listings.image%>" class="card-img-top show-img" alt="listings_image">
        <div class="card-body">
            <p class="card-text">
                <b><%=listings.title%></b><br/>
                <%= listings.title%><br/>
                ><%= listings.description%><br/>
                &#8377; <%= listings.price.toLocaleString("en-IN")%><br/>
                <%= listings.location%><br/>
                <%= listings.country%><br/>
            </p>    
        </div>
    </div>
    <div class="btns mt-3 mb-3">
        <a href="/listings/<%= listings._id%>/new " class="btn btn-dark edit-btn offset-2 col-1">Edit</a>
        <br/> <br/>
        <form  class="btn offset-1" method="post" action="/listings/<%=listings.id%>?_method=DELETE">
            <button class="btn offset-1 btn-danger">delete</button>
        </form>
    </div>
</div>